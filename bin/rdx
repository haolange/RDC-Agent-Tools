#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
tools_root=${RDX_TOOLS_ROOT:-$(CDPATH= cd -- "$script_dir/.." && pwd)}

if [ -n "${RDX_PYTHON:-}" ]; then
  python_cmd=$RDX_PYTHON
elif [ -x "$tools_root/binaries/windows/x64/python/python.exe" ]; then
  python_cmd="$tools_root/binaries/windows/x64/python/python.exe"
elif command -v python3 >/dev/null 2>&1; then
  python_cmd=python3
elif command -v python >/dev/null 2>&1; then
  python_cmd=python
else
  echo "[RDX][ERR] no runnable Python found; set RDX_PYTHON or restore the bundled runtime" >&2
  exit 2
fi

if [ "${1:-}" = "--non-interactive" ]; then
  shift
fi

export RDX_TOOLS_ROOT="$tools_root"
export PYTHONIOENCODING="${PYTHONIOENCODING:-utf-8}"
export RDX_LAUNCHER_PROG="${RDX_LAUNCHER_PROG:-rdx}"

exec "$python_cmd" "$tools_root/cli/run_cli.py" "$@"
