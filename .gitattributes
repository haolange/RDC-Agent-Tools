*.so filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.dylib filter=lfs diff=lfs merge=lfs -text
*.apk filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
*.pyd filter=lfs diff=lfs merge=lfs -text

# Keep vendored runtime files byte-for-byte stable.  These files are
# generated by scripts/package_runtime.py and are hash-checked by the runtime
# manifest, so platform line-ending conversion must never rewrite them.
binaries/windows/x64/python/** -text
binaries/windows/x64/pymodules/** -text
